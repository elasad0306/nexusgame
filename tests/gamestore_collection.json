    {
      "name": "4. Récupérer le jeu créé",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier que le jeu créé à l'étape 3 est bien récupérable.",
              "pm.test('Status de réponse 200', function(){",
              "    pm.response.to.have.status(200)",
              "})",
              "// Utiliser created_game_id (chaînage).",
              "pm.test(\"Vérifier l'id du jeu crée\", function(){",
              "    const game = pm.response.json()",
              "    pm.expect(game.id).to.eql(pm.collectionVariables.get('created_game_id'))",
              "})",
              "",
              "pm.test(\"L'ID correspond à celui créé à l'étape précédente\", function () {",
              "    const game = pm.response.json()",
              "    pm.expect(game.id).to.eql(pm.collectionVariables.get('created_game_id'));",
              "});",
              "// Vérifier le titre, le genre, le prix.",
              "",
              "pm.test(\"Vérification du titre, le genre, le prix\", () => {",
              "    const game = pm.response.json()",
              "",
              "    pm.expect(game.title).to.eql(\"Mario Kart\");",
              "    pm.expect(game.genre).to.eql(\"Arcade\");",
              "    pm.expect(game.price).to.eql(49.99);",
              "    ",
              "})"
            ],
