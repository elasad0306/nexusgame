    {
      "name": "2. Lister les jeux",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier :",
              "// - status 200",
              "pm.test('Status 200', () => {",
              "    pm.response.to.have.status(200)",
              "});",
              "// - réponse est un tableau",
              "pm.test(\"La réponse est un tableau\", function(){",
              "    const games = pm.response.json()",
              "",
              "    pm.expect(games).to.be.an('array')",
              "})",
              "// - tableau non vide",
              "pm.test(\"Le tableau contient au moins un jeu\", function () {",
              "    const games = pm.response.json()",
              "    ",
              "    pm.expect(games).to.be.an('array').and.not.empty",
              "})",
              "// - chaque jeu contient les champs attendus",
              "pm.test(\"Chaque jeu possède tous les champs obligatoires\", function () {",
              "    const games = pm.response.json()",
              "",
              "    games.forEach((game) => {",
              "        pm.expect(game).to.include.all.keys('id', 'title', 'genre', 'price');",
              "    })",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
